    OMRTEMPLATE {
        ObjectId _id PK
        string name
        string code UK
        string description
        object pageConfig
        object zones
        object scannerConfig
        enum level "school|system"
        ObjectId schoolId FK
        boolean isDefault
        number usageCount
        object templateJson
    }

    QUESTION {
        ObjectId _id PK
        string content
        enum type "single, multiple, true-false"
        array options
        string correctAnswer
        number score
