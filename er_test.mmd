    SCHOOL {
        ObjectId _id PK
        string name
        string code UK
        string address
        string phone
        string email
        string logoUrl
        string schoolType
        array gradeLevels
        boolean isActive
        string registrationStatus
    }

    CLASS {
        ObjectId _id PK
        string name
        string code UK
        number gradeLevel
        string academicYear
        ObjectId homeroomTeacherId FK
        array studentIds
        array subjectTeachers
