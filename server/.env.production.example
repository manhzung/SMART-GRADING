# ============================================================
# SMART GRADING - Production Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ============================================================
# MONGODB
# ============================================================
# Option A: MongoDB Atlas (RECOMMENDED - free tier available)
# Format: mongodb+srv://username:password@cluster.mongodb.net/smart-grading
# Get free cluster at: https://www.mongodb.com/atlas
MONGODB_URL=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/smart-grading

# Option B: Local MongoDB (if not using Atlas)
# MONGODB_URL=mongodb://admin:changeme@mongodb:27017/smart-grading?authSource=admin
# MONGO_USERNAME=admin
# MONGO_PASSWORD=changeme

# ============================================================
# AUTHENTICATION
# ============================================================
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-here
JWT_EXPIRES_IN=7d

# ============================================================
# AI PROVIDER (Gemini)
# ============================================================
# Get API key at: https://aistudio.google.com/
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================================
# CLOUDINARY (File uploads)
# ============================================================
# Get credentials at: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ============================================================
# WEBSOCKET
# ============================================================
# URL for WebSocket connections (update with your server IP/domain)
WS_URL=ws://YOUR_SERVER_IP:5000

# ============================================================
# SERVER CONFIG
# ============================================================
NODE_ENV=production
PORT=5000

# ============================================================
# AMC (Auto-Multiple-Choice)
# ============================================================
AMC_PROJECTS_DIR=/home/amc/amc-projects
